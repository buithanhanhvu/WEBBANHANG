				{
					"name": "1. [Thành công] Đăng ký khách hàng mới",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200 OK\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test(\"Response status is success\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.status).to.eql(\"success\");",
									"    pm.expect(jsonData.data).to.have.property(\"token\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"customer_test_postman\",\n  \"email\": \"customer_test_postman@gmail.com\",\n  \"password\": \"Password123\",\n  \"fullName\": \"Khách Hàng Thử Nghiệm Postman\",\n  \"phone\": \"0987654321\",\n  \"address\": \"123 Đường B, Hồ Chí Minh\"\n}"
