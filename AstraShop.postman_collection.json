				{
					"name": "2. [Thành công] Đăng nhập & Lấy Token tự động",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200 OK\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"var jsonData = pm.response.json();",
									"pm.test(\"Token exists and stored in collection variable\", function () {",
									"    pm.expect(jsonData.data).to.have.property(\"token\");",
									"    if (jsonData && jsonData.data && jsonData.data.token) {",
									"        pm.collectionVariables.set(\"token\", jsonData.data.token);",
									"        console.log(\"Đã lưu JWT Token tự động: \" + jsonData.data.token);",
									"    }",
									"});"
								],
								"type": "text/javascript"
							}
						}
